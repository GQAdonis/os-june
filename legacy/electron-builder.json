{
  "appId": "ai.os-notepad.mac",
  "productName": "OS Notepad",
  "asar": false,
  "npmRebuild": false,
  "files": [
    "electron/**",
    "native/bin/**",
    ".next/standalone/**",
    ".next/static/**",
    "public/**",
    "prisma/**",
    "dev.db",
    "package.json"
  ],
  "extraMetadata": {
    "main": "electron/main.cjs"
  },
  "mac": {
    "category": "public.app-category.productivity",
    "target": ["dmg", "zip"],
    "hardenedRuntime": false,
    "extendInfo": {
      "NSMicrophoneUsageDescription": "OS Notepad records meeting audio to transcribe notes."
    }
  },
  "directories": {
    "output": "dist"
  }
}
