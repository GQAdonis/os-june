// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  memberships  Membership[]
  notes        Note[]        @relation("NoteOwner")
  messages     ChatMessage[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  plan        Plan                   @default(BASIC)
  createdAt   DateTime               @default(now())
  memberships Membership[]
  spaces      Space[]
  calendar    CalendarConnection?
  subscription BillingSubscription?
  transcriptionSettings TranscriptionSettings?
}

model Membership {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String
  role        Role       @default(MEMBER)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Space {
  id          String     @id @default(cuid())
  name        String
  icon        String     @default("folder")
  workspaceId String
  createdAt   DateTime   @default(now())
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  notes       Note[]
}

model Note {
  id          String           @id @default(cuid())
  title       String
  status      NoteStatus       @default(DRAFT)
  visibility  Visibility       @default(PRIVATE)
  date        DateTime         @default(now())
  summary     String
  transcript  String
  aiModel     String           @default("mock-notes-v1")
  workspaceId String
  spaceId     String
  ownerId     String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  owner       User             @relation("NoteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  space       Space            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  turns       TranscriptTurn[]
  chunks      TranscriptChunk[]
  shares      Share[]
  messages    ChatMessage[]

  @@index([workspaceId, date])
}

model TranscriptTurn {
  id        String   @id @default(cuid())
  noteId    String
  speaker   String
  text      String
  startSec  Int
  endSec    Int
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model TranscriptChunk {
  id        String   @id @default(cuid())
  noteId    String
  source    String
  index     Int
  startSec  Int
  endSec    Int
  text      String
  status    String
  error     String?
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, source, index])
  @@index([noteId, index])
}

model CalendarConnection {
  id             String          @id @default(cuid())
  workspaceId    String          @unique
  provider       String
  providerUserId String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  connectedAt    DateTime        @default(now())
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  events         CalendarEvent[]
}

model CalendarEvent {
  id           String             @id @default(cuid())
  connectionId String
  title        String
  startsAt     DateTime
  endsAt       DateTime
  attendees    String
  source       String             @default("mock")
  connection   CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model Share {
  id        String   @id @default(cuid())
  noteId    String
  token     String   @unique
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  noteId    String?
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillingSubscription {
  id                 String      @id @default(cuid())
  workspaceId        String      @unique
  provider           String      @default("stripe")
  providerCustomerId String?
  providerSubscriptionId String?
  checkoutSessionId  String?
  status             BillingStatus @default(TRIALING)
  currentPeriodEnd   DateTime
  workspace          Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model TranscriptionSettings {
  id              String   @id @default(cuid())
  workspaceId     String   @unique
  provider        String
  model           String?
  baseUrl         String?
  encryptedApiKey String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum Plan {
  BASIC
  PRO
  TEAM
}

enum Role {
  OWNER
  MEMBER
}

enum NoteStatus {
  DRAFT
  RECORDING
  PROCESSING
  READY
}

enum Visibility {
  PRIVATE
  WORKSPACE
  PUBLIC
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}
